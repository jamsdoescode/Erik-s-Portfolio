DATABASE_URL="file:./prisma/dev.db"
JWT_SECRET="change-me-in-production"
ADMIN_EMAIL="your-admin-email@example.com"
ADMIN_PASSWORD="your-admin-password"
ADMIN_NAME="Admin"

# Production (Vercel): use Postgres, not SQLite.
# Connect Vercel Postgres/Neon, then set DATABASE_URL (or POSTGRES_PRISMA_URL) to the
# postgres:// connection string for Production, Preview, and Development environments.

# Production image uploads: connect Vercel Blob in the Storage tab.
# Vercel injects BLOB_READ_WRITE_TOKEN automatically when Blob is linked to the project.
