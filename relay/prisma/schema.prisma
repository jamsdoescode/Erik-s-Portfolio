generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model User {
  id           String      @id @default(cuid())
  email        String      @unique
  passwordHash String
  name         String
  timezone     String      @default("America/New_York")
  onboarded    Boolean     @default(false)
  activeLogId  String?
  plan         String      @default("trial")
  trialEndsAt  DateTime?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  sessions     Session[]
  projects     Project[]
  relayLogs    RelayLog[]
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
}

model Project {
  id          String     @id @default(cuid())
  userId      String
  name        String
  description String?
  color       String     @default("#22c55e")
  archived    Boolean    @default(false)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  relayLogs   RelayLog[]

  @@index([userId])
}

model RelayLog {
  id           String    @id @default(cuid())
  userId       String
  projectId    String?
  title        String
  body         String?
  accomplished String?
  nextStep     String?
  blockers     String?
  startedAt    DateTime  @default(now())
  endedAt      DateTime?
  durationSec  Int?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  project      Project?  @relation(fields: [projectId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([projectId])
  @@index([startedAt])
}
